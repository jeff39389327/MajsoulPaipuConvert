# 雀魂認證設定
# 使用中國伺服器 (maj-soul.com)。複製本檔為 config.env 後填入帳密即可，
# 純 API 登入下載（免瀏覽器、免手動 token）—— 見 ms_patch.py。
ms_username=your_email@example.com
ms_password=your_password

# (進階) 雀魂大改版資源後若登入回 error 151，GUI 會自動抓取最新版本、重試並寫回此值；
# 通常無需手動設定。亦可手動固定指定版本（預設見 ms_patch.py）。
# 來源：瀏覽器登入雀魂後 localStorage 的 prev_res_version。
# 留空時視同未設定，回退 ms_patch.py 內建預設值（不要寫成 MS_RES_VERSION= 空字串以外的無效值）。
# MS_RES_VERSION=0.16.230

# 使用國際伺服器 (mahjongsoul.com) - 可選
# ms_uid=your_uid_here
# ms_token=your_token_here

# 思考時間收集設定
# 設為 true 啟用，false 停用（默認：true）
# 啟用後會在 mjai 格式中添加 think_ms 字段，記錄玩家每個動作的思考時間（毫秒）
COLLECT_TIMING=true

# 保存雀魂原始JSON設定
# 設為 true 啟用，false 停用（默認：false）
# 啟用後會將雀魂原始的GameDetailRecords JSON保存到 mahjong_logs/raw_json/ 目錄
# 包含完整的actions數據，可用於深度分析或調試
# 注意：啟用此選項會自動啟用COLLECT_TIMING
SAVE_RAW_JSON=true

